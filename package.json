{
  "name": "amazon-order-lens",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Lokale Analyse-App für Amazon-Kaufhistorien aus dem GDPR-Export — alle Daten bleiben im Browser.",
  "license": "MIT",
  "author": {
    "name": "Piotr Großmann",
    "email": "heypiotr@posteo.de"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"e2e/**/*.ts\""
  },
  "dependencies": {
    "jszip": "3.10.1",
    "papaparse": "5.5.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "recharts": "3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.59.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.6.0",
    "@types/papaparse": "5.5.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.58.2",
    "@typescript-eslint/parser": "8.58.2",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.4",
    "eslint": "10.2.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "fake-indexeddb": "6.2.5",
    "globals": "17.5.0",
    "jsdom": "29.0.2",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "vite": "8.0.8",
    "vitest": "4.1.4"
  }
}
